{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "xbloom-recipe.schema.json",
  "title": "xBloom Recipe",
  "description": "Recipe format for xBloom BLE brew scripts and REST API.",
  "type": "object",
  "required": ["pours"],
  "properties": {
    "cup_type": {
      "type": "string",
      "enum": ["xpod", "xdripper", "other", "tea"],
      "default": "other",
      "description": "Cup type. Determines the cup weight range sent to the machine via BLE command 8104."
    },
    "dose": {
      "type": "number",
      "minimum": 0,
      "default": 0,
      "description": "Coffee dose in grams."
    },
    "grinder": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["size", "rpm"],
          "properties": {
            "size": {
              "type": "integer",
              "minimum": 1,
              "maximum": 80,
              "description": "Grinder size (1-80)."
            },
            "rpm": {
              "type": "integer",
              "minimum": 60,
              "maximum": 120,
              "description": "Grinder speed RPM. Official app values: 60, 70, 80, 90, 100, 110, 120."
            }
          },
          "additionalProperties": false
        }
      ],
      "default": null,
      "description": "Grinder settings. null = grinder OFF."
    },
    "temperature": {
      "type": "number",
      "minimum": 40,
      "maximum": 98,
      "default": 91,
      "description": "Default brew temperature in °C for all pours. Individual pours may override."
    },
    "pattern": {
      "type": "string",
      "enum": ["center", "circular", "spiral"],
      "default": "center",
      "description": "Pour pattern."
    },
    "vibration": {
      "type": "string",
      "enum": ["none", "before", "after", "both"],
      "default": "none",
      "description": "Vibration mode."
    },
    "flow_rate": {
      "type": "number",
      "minimum": 3.0,
      "maximum": 3.5,
      "default": 3.0,
      "description": "Water flow speed."
    },
    "pours": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["volume", "post_wait"],
        "properties": {
          "volume": {
            "type": "number",
            "exclusiveMinimum": 0,
            "description": "Water volume in ml."
          },
          "post_wait": {
            "type": "integer",
            "minimum": 0,
            "maximum": 59,
            "description": "Seconds to pause after this pour ends."
          },
          "temperature": {
            "type": "number",
            "minimum": 40,
            "maximum": 98,
            "description": "Per-pour temperature override in °C."
          },
          "vibration": {
            "type": "string",
            "enum": ["none", "before", "after", "both"],
            "description": "Per-pour vibration override."
          },
          "pattern": {
            "type": "string",
            "enum": ["center", "circular", "spiral"],
            "description": "Per-pour pattern override."
          },
          "flow_rate": {
            "type": "number",
            "minimum": 3.0,
            "maximum": 3.5,
            "description": "Per-pour flow rate override."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
